{
  "compilerOptions": {
    "target": "esnext",
    "useDefineForClassFields": true,
    "module": "esnext",
    // TS 6.0 废弃了 "node"/"node10"; 本项目由 Vite/Rolldown 打包, 语义正确且面向未来的解析模式是 "bundler".
    "moduleResolution": "bundler",
    "strict": true,
    "jsx": "preserve",
    "sourceMap": true,
    "jsxImportSource": "vue",
    "resolveJsonModule": true,
    "esModuleInterop": true,
    "lib": ["esnext", "dom"],
    // TS 6.0 废弃了 baseUrl; paths 自 TS4.1 起无需 baseUrl, 直接相对 tsconfig 目录解析 (写成显式 ./ 前缀).
    "paths": {
      "@/*": ["./src/*"]
    },
    "skipLibCheck": true,
  },
  "include": ["src/**/*.ts", "src/**/*.d.ts", "src/**/*.tsx", "src/**/*.vue", "mock/index.d.ts"],
  // 编译器默认排除的编译文件
  "exclude": ["node_modules"],
  // ts-node 特殊编译选项
  "ts-node": {
    "compilerOptions": {
      "target": "es2020",
      "experimentalDecorators": true,
      "emitDecoratorMetadata": true,
      "useDefineForClassFields": true,
      "forceConsistentCasingInFileNames": true,
      "module": "CommonJS"
    }
  }
}
