{
  "schemaVersion": 1,
  "cases": [
    {
      "id": "gt_string_allow",
      "description": "GreaterThan 字符串比较命中",
      "policies": [
        {
          "id": "policy.gt.allow",
          "name": "gt",
          "effect": "ALLOW",
          "rules": [
            {
              "groupType": "ALL",
              "rule": [
                { "type": "Environment", "operator": "GreaterThan", "key": "time", "value": "16:00" }
              ]
            }
          ]
        }
      ],
      "request": {
        "subject": {}, "action": {}, "resource": {},
        "environment": { "time": "16:15" }
      },
      "expected": { "outcome": "allow" }
    },
    {
      "id": "gt_string_deny",
      "description": "GreaterThan 字符串比较不命中",
      "policies": [
        {
          "id": "policy.gt.allow", "name": "gt", "effect": "ALLOW",
          "rules": [
            { "groupType": "ALL", "rule": [ { "type": "Environment", "operator": "GreaterThan", "key": "time", "value": "16:00" } ] }
          ]
        }
      ],
      "request": {
        "subject": {}, "action": {}, "resource": {},
        "environment": { "time": "15:00" }
      },
      "expected": { "outcome": "deny" }
    },
