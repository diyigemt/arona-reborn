{
  "schemaVersion": 1,
  "cases": [
    {
      "id": "isin_allow",
      "description": "Subject.id IsIn [a,b,c] 命中 a",
      "policies": [
        {
          "id": "policy.isin.allow", "name": "isin", "effect": "ALLOW",
          "rules": [
            { "groupType": "ALL", "rule": [ { "type": "Subject", "operator": "IsIn", "key": "id", "value": "user.a,user.b,user.c" } ] }
          ]
        }
      ],
      "request": {
        "subject": { "id": "user.a" },
        "action": {}, "resource": {}, "environment": {}
      },
      "expected": { "outcome": "allow" }
    },
    {
      "id": "isin_deny",
      "description": "Subject.id IsIn 不命中",
      "policies": [
        {
          "id": "policy.isin.allow", "name": "isin", "effect": "ALLOW",
          "rules": [
            { "groupType": "ALL", "rule": [ { "type": "Subject", "operator": "IsIn", "key": "id", "value": "user.a,user.b" } ] }
          ]
        }
      ],
      "request": {
        "subject": { "id": "user.z" },
        "action": {}, "resource": {}, "environment": {}
      },
      "expected": { "outcome": "deny" }
    },
    {
