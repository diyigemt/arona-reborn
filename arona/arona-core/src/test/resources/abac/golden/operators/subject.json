        {
          "id": "p", "name": "p", "effect": "ALLOW",
          "rules": [ { "groupType": "ALL", "rule": [ { "type": "Subject", "operator": "IsIn", "key": "id", "value": "u1,u2" } ] } ]
        }
      ],
      "request": { "subject": { "id": "u2" }, "action": {}, "resource": {}, "environment": {} },
      "expected": { "outcome": "allow" }
    },
    {
      "id": "subject_roles_contains_any_allow",
