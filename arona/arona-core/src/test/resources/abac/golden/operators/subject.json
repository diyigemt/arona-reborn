  "cases": [
    {
      "id": "subject_id_equal_allow",
      "description": "Subject.id Equal 命中",
      "policies": [
        {
          "id": "p", "name": "p", "effect": "ALLOW",
          "rules": [ { "groupType": "ALL", "rule": [ { "type": "Subject", "operator": "Equal", "key": "id", "value": "u1" } ] } ]
        }
      ],
      "request": { "subject": { "id": "u1" }, "action": {}, "resource": {}, "environment": {} },
      "expected": { "outcome": "allow" }
    },
    {
      "id": "subject_id_is_in_list_allow",
      "description": "Subject.id IsIn [u1,u2] 命中 u2",
