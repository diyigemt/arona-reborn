        {
          "id": "p", "name": "p", "effect": "ALLOW",
          "rules": [ { "groupType": "ALL", "rule": [ { "type": "Subject", "operator": "ContainsAll", "key": "roles", "value": "role.a,role.b" } ] } ]
        }
      ],
      "request": { "subject": { "roles": ["role.a"] }, "action": {}, "resource": {}, "environment": {} },
      "expected": { "outcome": "deny" }
